JWT_SECRET=replace-with-a-long-random-secret
PORT=3001
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# Auth v1 authority configuration.
AUTH_ISSUER=brandsoul-auth
AUTH_AUDIENCE=brandsoul-api
AUTH_ACCESS_TOKEN_TTL_SECONDS=600
AUTH_REFRESH_TOKEN_TTL_DAYS=14
AUTH_CLOCK_TOLERANCE_SECONDS=60
AUTH_ACTIVE_KID=
AUTH_PRIVATE_KEY_REF=
AUTH_PUBLIC_KEY_PATH=

# Optional storage settings.
ASSET_STORAGE_PROVIDER=local
ASSET_STORAGE_DIR=./data/assets
ASSET_PUBLIC_BASE_PATH=/assets