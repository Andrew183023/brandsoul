{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2023",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": [
    "src/main.tsx",
    "src/App.tsx",
    "src/index.css",
    "src/App.css",
    "src/assets/**/*",
    "src/styles/**/*.css",
    "src/data/**/*.ts",
    "src/types/**/*.ts",
    "src/lib/**/*.ts",
    "src/lib/**/*.tsx",
    "src/pages/**/*.ts",
    "src/pages/**/*.tsx",
    "src/backend-bridge/api/authHeaders.ts",
    "src/backend-bridge/api/publicEntityApi.ts",
    "src/backend-bridge/api/publicEntityInteractionApi.ts",
    "src/backend-bridge/api/publicSocialApi.ts",
    "src/backend-bridge/api/entityExportApi.ts",
    "src/backend-bridge/contracts/PublicEntityDecisionResponse.ts",
    "src/domain/entity/contracts/PublicPresenceResponse.ts",
    "src/domain/entity/contracts/EntityPublicProfile.ts",
    "src/domain/identity/contracts/**/*.ts",
    "src/domain/identity/services/**/*.ts",
    "src/domain/rendering/contracts/BrandSoulVisualRuntimePatch.ts",
    "src/app/AdminApp.tsx",
    "src/app/dashboard/PixiPresenceMini.tsx",
    "src/app/styles/globals.css"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/features/**",
    "src/persona-lab/**",
    "src/personaLab/**",
    "src/runtime/**",
    "src/export/**",
    "src/domain/orchestration/**",
    "src/domain/base-form/**",
    "src/domain/entity/engine/**",
    "src/domain/entity/mappers/**",
    "src/domain/manifestation/**",
    "src/domain/materialization/**",
    "src/domain/monetization/**",
    "src/domain/persona-dna/**",
    "src/domain/rendering/contracts/RuntimeSceneSpec.ts",
    "src/domain/rendering/contracts/types.ts",
    "src/domain/rendering/resolvers/**",
    "src/domain/rendering/services/**",
    "src/domain/shape/**",
    "src/domain/visual-archetype/**",
    "src/components/**",
    "src/backend-bridge/api/entityInteractionApi.ts",
    "src/backend-bridge/api/monetizationApi.ts",
    "src/backend-bridge/api/orchestratorApi.ts",
    "src/backend-bridge/api/personaEngineApi.ts",
    "src/backend-bridge/contracts/CommandRequest.ts",
    "src/backend-bridge/contracts/CommandResponse.ts",
    "src/backend-bridge/contracts/DashboardSparkStateResponse.ts",
    "src/backend-bridge/contracts/HydrateRuntimeResponse.ts",
    "src/backend-bridge/contracts/OrchestratorFrame.ts",
    "src/backend-bridge/contracts/RelationalTraceDetailedResponse.ts",
    "src/lib/sparkApi.ts"
  ]
}
